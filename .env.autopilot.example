# Copy this file to .env.autopilot and fill in real values.
# .env.autopilot is gitignored — NEVER commit real credentials.
#
# Purpose: gives the autopilot container AWS credentials so it can run
# `cdk deploy`, hit AWS APIs, and verify its own work end-to-end.
#
# Scope the IAM user to: cloudformation:*, lambda:*, apigateway:*,
# s3:* on cdk-hnb659fds-* buckets, iam:PassRole on stack execution roles,
# logs:*, ssm:GetParameter on /cdk-bootstrap/*. Or reuse your laptop's
# CLI credentials — same blast radius since they already exist locally.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
