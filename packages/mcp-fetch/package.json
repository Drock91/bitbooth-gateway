    "crypto-payments",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "continue-dev",
    "anthropic",
    "bitbooth"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ethers": "^6.13.0",
    "zod": "^3.25.0"
  },
