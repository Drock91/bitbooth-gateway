  },
  "homepage": "https://github.com/Drock91/bitbooth-gateway/tree/main/packages/mcp-fetch",
  "bugs": {
    "url": "https://github.com/Drock91/bitbooth-gateway/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mcp-fetch": "./bin/mcp-fetch.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./server": "./src/server.js",
    "./x402-client": "./src/x402-client.js"
  },
  "files": [
