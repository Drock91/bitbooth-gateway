# Runtime (loaded from Secrets Manager in AWS; local dev only)
AWS_REGION=us-east-1
STAGE=dev

# Base mainnet (EVM)
# CHAIN_RPC_URL is optional — in prod, RPC URL is loaded from BASE_RPC_SECRET_ARN
CHAIN_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
AGENT_WALLET_SECRET_ARN=arn:aws:secretsmanager:...:agent-wallet
BASE_RPC_SECRET_ARN=

# x402
X402_PAYMENT_WINDOW_SECONDS=120
X402_REQUIRED_CONFIRMATIONS=2

# Exchanges (ARNs in prod; inline for dev only)
MOONPAY_API_KEY_SECRET_ARN=
COINBASE_API_KEY_SECRET_ARN=
KRAKEN_API_KEY_SECRET_ARN=
BINANCE_API_KEY_SECRET_ARN=
UPHOLD_API_KEY_SECRET_ARN=
